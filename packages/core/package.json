{
  "name": "@desktalk/core",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "desktalk": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths --resolve-full-extension .js && node ./scripts/copy-manual-pages.mjs && vite build",
    "build:server": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths --resolve-full-extension .js && node ./scripts/copy-manual-pages.mjs",
    "build:frontend": "vite build",
    "start": "node dist/cli/index.js start",
    "dev": "pnpm run build:server && pnpm run --parallel \"/dev:/\"",
    "dev:backend": "node dist/cli/index.js start --dev",
    "dev:frontend": "vite",
    "clean": "rm -rf dist",
    "unit:test": "vitest run"
  },
  "dependencies": {
    "@desktalk/miniapp-file-explorer": "workspace:*",
    "@desktalk/miniapp-note": "workspace:*",
    "@desktalk/miniapp-player": "workspace:*",
    "@desktalk/miniapp-preference": "workspace:*",
    "@desktalk/miniapp-preview": "workspace:*",
    "@desktalk/miniapp-terminal": "workspace:*",
    "@desktalk/miniapp-text-edit": "workspace:*",
    "@desktalk/sdk": "workspace:*",
    "@desktalk/ui": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@mariozechner/pi-ai": "^0.62.0",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@sinclair/typebox": "^0.34.48",
    "ahooks": "^3.9.6",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "commander": "^13.0.0",
    "culori": "^4.0.2",
    "env-paths": "^3.0.0",
    "fastify": "^5.0.0",
    "monaco-editor": "^0.52.0",
    "partial-json": "^0.1.7",
    "pino": "^10.3.1",
    "sharp": "^0.34.5",
    "undici": "^7.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/culori": "^4.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "magic-string": "^0.30.17",
    "pino-pretty": "^13.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "^1.86.3",
    "streamdown": "^2.4.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0",
    "zustand": "^5.0.0"
  }
}
